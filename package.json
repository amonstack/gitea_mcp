{
  "name": "@amonstack/gitea-mcp",
  "version": "0.0.0",
  "description": "MCP server for managing Gitea issues via API",
  "repository": {
    "type": "git",
    "url": "https://github.com/amonstack/gitea_mcp.git"
  },
  "homepage": "https://github.com/amonstack/gitea_mcp#readme",
  "bugs": {
    "url": "https://github.com/amonstack/gitea_mcp/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gitea-mcp": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && npm run build:assets",
    "build:assets": "node scripts/copy-assets.mjs",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "lint": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "smoke": "node scripts/smoke.mjs",
    "scan": "gitleaks detect --source . --redact --report-format json -r .dist/leaks.json --no-banner"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "gitea",
    "issues"
  ],
  "author": "amonstack",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
